    sensor.riskLevel === "high" ? "bg-gh-red-light border-gh-red/20" :
    sensor.riskLevel === "moderate" ? "bg-gh-orange-light border-gh-orange/20" :
    "bg-gh-green-light border-gh-green/20";

  const filteredDiseases = diseases.filter(
    (d) =>
      d.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      d.crops.some((c) => c.toLowerCase().includes(searchQuery.toLowerCase()))
  );

  return (
    <div className="space-y-6">
      {/* ── Live Sensor Readings ───────────────────────────── */}
