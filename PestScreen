                          ? "bg-gh-green-light text-gh-green"
                          : log.outcome === "Monitoring"
                          ? "bg-gh-orange-light text-gh-orange"
                          : "bg-gh-blue-light text-gh-blue"
                      }`}
                    >
                      {log.outcome}
                    </span>
                  </TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </div>
      </section>
    </div>
  );
};

export default PestScreen;
