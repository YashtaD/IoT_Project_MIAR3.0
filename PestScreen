import bacterialSpotImg from "@/assets/bacterial-spot.jpg";
import rustDiseaseImg from "@/assets/rust-disease.jpg";

/* ── Simulated sensor stream ─────────────────────────────── */
function rand(min: number, max: number) {
  return +(min + Math.random() * (max - min)).toFixed(1);
}

interface SensorSnapshot {
  temperature: number;
  humidity: number;
  riskLevel: "safe" | "moderate" | "high";
}

function genSnapshot(): SensorSnapshot {
  const t = rand(20, 40);
  const h = rand(30, 90);
  return {
    temperature: t,
    humidity: h,
    riskLevel: h > 75 ? "high" : h > 60 ? "moderate" : "safe",
  };
}


