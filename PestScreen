          <button
            onClick={refresh}
            className="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 transition-colors"
          >
            <RefreshCw className={`w-3 h-3 ${isUpdating ? "animate-spin" : ""}`} />
            {isUpdating ? "Updating…" : "Live"}
            <span className="w-1.5 h-1.5 rounded-full bg-gh-green animate-pulse" />
          </button>
        </div>

        <div className={`grid grid-cols-3 gap-3 transition-all duration-300 ${isUpdating ? "opacity-70 scale-[0.99]" : "opacity-100 scale-100"}`}>
          {/* Temperature */}
          <div className="bg-card rounded-lg border border-border p-4 shadow-sm text-center">
            <Thermometer className="w-5 h-5 text-gh-red mx-auto mb-1" />
            <p className="text-2xl font-bold text-foreground">{sensor.temperature}°C</p>
            <p className="text-[10px] text-muted-foreground">Temperature</p>
          </div>
          {/* Humidity */}
          <div className="bg-card rounded-lg border border-border p-4 shadow-sm text-center">
            <Droplets className="w-5 h-5 text-gh-blue mx-auto mb-1" />
            <p className="text-2xl font-bold text-foreground">{sensor.humidity}%</p>
            <p className="text-[10px] text-muted-foreground">Humidity</p>
          </div>
          {/* Risk Level */}
          <div className={`rounded-lg border p-4 shadow-sm text-center ${riskBg}`}>
            <Shield className={`w-5 h-5 mx-auto mb-1 ${riskColor}`} />
            <p className={`text-sm font-bold capitalize ${riskColor}`}>
              {sensor.riskLevel === "high" ? "High Fungal Risk" : sensor.riskLevel === "moderate" ? "Moderate Risk" : "Safe"}
            </p>
            <p className="text-[10px] text-muted-foreground">Disease Risk</p>
          </div>
        </div>
      </section>

      {/* Risk alert banner removed per request */}

      {/* ── Active Pest/Disease Alerts ─────────────────────── */}
      <section>
        <h2 className="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">
          Active Pest/Disease Alerts
        </h2>
        <div className="space-y-2.5">
          {pestAlerts.map((a) => (
            <div
              key={a.id}
              className={`flex items-start gap-3 rounded-lg p-4 border shadow-sm ${
                a.severity === "critical"
                  ? "bg-gh-red-light border-gh-red/20"
                  : "bg-gh-orange-light border-gh-orange/20"
              }`}
            >
              <Bug className={`w-4 h-4 mt-0.5 shrink-0 ${a.severity === "critical" ? "text-gh-red" : "text-gh-orange"}`} />
              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium text-foreground">{a.title}</p>
                <p className="text-xs text-muted-foreground">{a.zone} · {a.time}</p>
                <p className="text-xs text-secondary font-medium mt-1">→ {a.action}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* ── AI Plant Analysis (upload) ────────────────────── */}
