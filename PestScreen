/* ── Component ───────────────────────────────────────────── */
const PestScreen = () => {
  const [sensor, setSensor] = useState<SensorSnapshot>(genSnapshot);
  const [isUpdating, setIsUpdating] = useState(false);
  const [searchQuery, setSearchQuery] = useState("");

  const refresh = useCallback(() => {
    setIsUpdating(true);
    setTimeout(() => {
      setSensor(genSnapshot());
      setIsUpdating(false);
    }, 300);
  }, []);

  useEffect(() => {
    const id = setInterval(refresh, 5000);
    return () => clearInterval(id);
  }, [refresh]);

